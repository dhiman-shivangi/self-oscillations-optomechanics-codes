Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"d1p3", "=", 
    RowBox[{"ParallelTable", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"k", ",", "l", ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"fixedpointevo", "[", 
            RowBox[{"k", ",", "l"}], "]"}], "[", 
           RowBox[{"[", "3", "]"}], "]"}], ")"}], "+", 
         RowBox[{"2", "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"fixedpointevo", "[", 
             RowBox[{"k", ",", "l"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}], ")"}]}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", 
        RowBox[{"-", "2"}], ",", "2", ",", "0.01"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"l", ",", "0.001", ",", "4", ",", "0.01"}], "}"}]}], "]"}]}], 
   ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Obtain", " ", "a", " ", 
     RowBox[{"(", 
      RowBox[{"x", ",", "y", ",", "z"}], ")"}], " ", "list", " ", "where", 
     " ", "x", " ", "corresponds", " ", "to", " ", "the", " ", "detuning"}], 
    ",", " ", 
    RowBox[{
    "y", " ", "corresponds", " ", "to", " ", "the", " ", "input", " ", 
     "power"}], ",", " ", 
    RowBox[{
    "and", " ", "z", " ", "gives", " ", "a", " ", "unique", " ", "number", 
     " ", "that", " ", "tells", " ", "us", " ", "about", " ", "the", " ", 
     "number", " ", "of", " ", "stable", " ", "and", " ", "unstable", " ", 
     "solutions", " ", "for", " ", "the", " ", "fixed", " ", 
     RowBox[{"points", ".", " ", "Here"}], " ", "0", "corresponds", " ", "to",
      " ", "single", " ", "stable", " ", "fixed", " ", "point"}], ",", " ", 
    RowBox[{
    "1", " ", "corresponds", " ", "to", " ", "Single", " ", "unstable", " ", 
     "fixed", " ", "point"}], ",", " ", 
    RowBox[{
    "2", " ", "corresponds", " ", "to", " ", "single", " ", "stable", " ", 
     "fixed", " ", "point"}], ",", 
    RowBox[{
    "4", " ", "corresponds", " ", "to", " ", "single", " ", "stable", " ", 
     "and", " ", "two", " ", "unstable", " ", "fixed", " ", "points", " ", 
     "and", " ", "5", " ", "corresponds", " ", "to", " ", "two", " ", 
     "stable", " ", "and", " ", "one", " ", "unstable", " ", "fixed", " ", 
     RowBox[{"point", ".", " ", "Note"}], " ", "that", " ", "3", " ", "does", 
     " ", "not", " ", "correspond", " ", "to", " ", "any", " ", 
     RowBox[{"case", "."}]}]}], "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
