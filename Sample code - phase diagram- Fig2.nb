    " ", "-", " ", "non", "-", 
    RowBox[{"representable", " ", "number"}]}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
   "Clears", " ", "all", " ", "previously", " ", "defined", " ", 
    "variables"}], "*)"}]}]}], "Input",
 CellChangeTimes->{
  3.955593217804019*^9},ExpressionUUID->"7ce5c073-0bcd-45ae-9b91-\
8a93db0a9d03"],

