    " ", "-", " ", "non", "-", 
    RowBox[{"representable", " ", "number"}]}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], "  ", 
  RowBox[{"(*", 
   RowBox[{
   "Clears", " ", "all", " ", "previously", " ", "defined", " ", 
    "variables"}], "*)"}]}]}], "Input",
 CellChangeTimes->{3.955593217804019*^9},
