   RowBox[{
   "Clears", " ", "all", " ", "previously", " ", "defined", " ", 
    "variables"}], "*)"}]}]], "Input",
 CellChangeTimes->{
  3.955442396786212*^9},ExpressionUUID->"8603a40a-9f8c-43d4-b12b-\
807626d2afe3"],

