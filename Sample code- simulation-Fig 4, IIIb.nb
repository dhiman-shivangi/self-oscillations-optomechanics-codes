     "decay", " ", 
    RowBox[{"rate", "."}]}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g0", "=", 
    FractionBox[
     RowBox[{"2", "*", "Pi", "*", "4.691", "*", 
      RowBox[{"10", "^", "3"}]}], 
     RowBox[{"(", 
      RowBox[{"2", "*", "Pi", "*", "5.607483", "*", 
