      RowBox[{"{", 
       RowBox[{"i", ",", 
        RowBox[{"-", "1.5"}], ",", "2", ",", "0.1"}], "}"}]}], "]"}]}], ";"}],
   "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Export", "[", 
   RowBox[{"\"\<S21-sample-data\>\"", ",", "scatsim"}], "]"}], " ", 
  RowBox[{"(*", 
   RowBox[{
   "To", " ", "export", " ", "the", " ", "generated", " ", "table", " ", "in",
