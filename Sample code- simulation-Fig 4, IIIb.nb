     RowBox[{"(", 
      RowBox[{"2", "*", "Pi", "*", "11.7"}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{"2", "*", "Pi", "*", "5.606456", "*", 
       RowBox[{"10", "^", "6"}]}], ")"}]}]}], ";"}], " ", 
  RowBox[{"(*", 
